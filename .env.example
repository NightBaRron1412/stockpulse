# ============================================================
# StockPulse Configuration
# ============================================================
# Copy this file to .env: cp .env.example .env
# Only FINNHUB_API_KEY is required. Everything else is optional.
# ============================================================

# ── REQUIRED ──────────────────────────────────────────────────
# Get a free API key at https://finnhub.io (60 requests/min)
FINNHUB_API_KEY=

# ── DATA SETTINGS (optional) ─────────────────────────────────
# Max Yahoo Finance API calls per hour (default: 2000)
YAHOO_RATE_LIMIT=2000
# How long to cache API responses in minutes (default: 15)
CACHE_TTL_MINUTES=15

# ── LLM / AI SUMMARIES (optional) ────────────────────────────
# Set to false to use rules-based summaries instead of AI
LLM_ENABLED=true
# API endpoint for Claude (default: Anthropic)
LLM_BASE_URL=https://api.anthropic.com
# Your Anthropic API key (or leave blank to use ANTHROPIC_API_KEY env var)
LLM_API_KEY=
# Model to use (default: claude-sonnet-4-6)
LLM_MODEL=claude-sonnet-4-6

# ── TELEGRAM ALERTS (optional) ───────────────────────────────
# Set to true to receive alerts via Telegram
ALERTS_TELEGRAM=false
# Create a bot via @BotFather on Telegram to get these
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── DISCORD ALERTS (optional) ────────────────────────────────
# Set to true to receive alerts via Discord webhook
ALERTS_DISCORD=false
# Create a webhook in your Discord channel settings
DISCORD_WEBHOOK_URL=

# ── TRADING MODE (safety) ────────────────────────────────────
# Paper mode by default. DO NOT change unless you know what you're doing.
TRADING_ENABLED=false
TRADING_MODE=paper

# ── SEC EDGAR (optional) ─────────────────────────────────────
# SEC requires a user agent string for EDGAR API access
SEC_USER_AGENT=stockpulse your_email@example.com
